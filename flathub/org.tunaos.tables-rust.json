{
  "app-id": "org.tunaos.tables-rust",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "tables",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--own-name=org.tunaos.tables-rust",
    "--filesystem=xdg-documents"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/tables-rust/cargo"
    }
  },
  "modules": [
    {
      "name": "tables-rust",
      "buildsystem": "simple",
      "build-commands": [
        "cargo --offline build --release -p tables",
        "install -Dm755 target/release/tables /app/bin/tables",
        "install -Dm644 flatpak/org.tunaos.tables-rust.desktop /app/share/applications/org.tunaos.tables-rust.desktop",
        "install -Dm644 flatpak/org.tunaos.tables-rust.gschema.xml /app/share/glib-2.0/schemas/org.tunaos.tables-rust.gschema.xml",
        "glib-compile-schemas /app/share/glib-2.0/schemas/",
        "install -Dm644 flatpak/icons/org.tunaos.tables-rust.svg /app/share/icons/hicolor/scalable/apps/org.tunaos.tables-rust.svg",
        "install -Dm644 flatpak/org.tunaos.tables-rust.metainfo.xml /app/share/metainfo/org.tunaos.tables-rust.metainfo.xml"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/tuna-os/gtk-office-suite.git",
          "tag": "v1.1.0"
        },
        "cargo-sources.json"
      ]
    }
  ]
}