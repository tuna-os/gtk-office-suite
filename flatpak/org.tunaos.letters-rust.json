{
  "app-id": "org.tunaos.letters-rust",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "tables",
  "finish-args": ["--share=ipc", "--socket=fallback-x11", "--socket=wayland", "--device=dri"],
  "build-options": {
    "build-args": ["--share=network"],
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "modules": [{
    "name": "letters-rust",
    "buildsystem": "simple",
    "build-commands": [
      "cargo build --release",
      "install -Dm755 target/release/tables /app/bin/tables"
    ],
    "sources": [{
      "type": "dir",
      "path": ".."
    }]
  }]
}
